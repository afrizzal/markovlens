# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# Virtual env
.venv/
venv/
ENV/
env/

# UV
.uv-cache/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Streamlit secrets (committable: config.toml; uncommittable: secrets.toml)
.streamlit/secrets.toml

# Data — never commit raw or compiled
data/markovlens.duckdb
data/markovlens.duckdb.wal
data/raw/*.csv
data/raw/*.parquet
data/raw/*.zip
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/cache/*
!data/cache/.gitkeep
# Seed reference datasets are tracked (D-03) — small, publicly redistributable, needed for cold-start deploy
!data/seed/
!data/seed/*.csv

# Reports — generated outputs
reports/exports/*
!reports/exports/.gitkeep

# Testing
.pytest_cache/
.pytest_tmp/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
coverage.xml
*.cover

# Env
.env
.env.local
*.env.local
!.env.example

# Logs
*.log
logs/

# GSD planning runtime artifacts (PROJECT/ROADMAP/STATE committed; temp not)
.planning/temp/

# Claude Code local overrides
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock
